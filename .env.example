# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Firebase Admin — UNE des options suivantes :

# Option A (recommandé Railway) : JSON téléchargé depuis Firebase, encodé en base64 sur une seule ligne
#   macOS/Linux : base64 -i serviceAccountKey.json | tr -d '\n'
#   Puis coller le résultat dans Railway → Variable FIREBASE_SERVICE_ACCOUNT_BASE64
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Option B : JSON complet sur une ligne (échapper les guillemets si besoin)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option C : trois variables (souvent fragile sur Railway à cause des \n dans la clé)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optionnel — port HTTP (défaut: 3000)
# PORT=3000

# Optionnel — CORS
# CORS_ORIGIN=https://example.com
