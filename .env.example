# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Firebase Admin — Service account JSON (Project settings → Service accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Clé privée sur une seule ligne, avec \n pour les retours à la ligne
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optionnel — port HTTP (défaut: 3000)
# PORT=3000

# Optionnel — CORS : URL exacte ou * (défaut: toutes origines autorisées)
# CORS_ORIGIN=https://example.com
